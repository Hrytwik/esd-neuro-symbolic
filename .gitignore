# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter notebooks (exploration only — not part of platform)
.ipynb_checkpoints/

# Data cache (dataset downloaded locally — do not commit raw data)
data/cache/
data/raw/*.data
data/raw/*.names

# Large output artifacts (figures, generated reports)
outputs/figures/*.png
outputs/figures/*.pdf
outputs/tables/*.csv
outputs/traces/*.json
outputs/reports/*.pdf

# Keep output directory structure
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/traces/.gitkeep
!outputs/reports/.gitkeep

# Pipeline runtime outputs (reasoning traces, escalation reports, replays, narratives)
# These are generated at runtime and must not be committed.
outputs/reasoning_traces/*.json
outputs/escalation_reports/*.json
outputs/replay_snapshots/*.json
outputs/narratives/*.txt
outputs/validation_runs/*.json

# Preserve the directory markers
!outputs/reasoning_traces/.gitkeep
!outputs/escalation_reports/.gitkeep
!outputs/replay_snapshots/.gitkeep
!outputs/narratives/.gitkeep
!outputs/validation_runs/.gitkeep

# Reproducibility packages (generated artifacts)
outputs/reproducibility_*/

# Environment snapshots
.env.local
*.env

# Windows
desktop.ini
